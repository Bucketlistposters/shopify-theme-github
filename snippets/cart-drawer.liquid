{% comment %}
  Enhanced Cart Drawer - Upfront style
  Features: free shipping progress bar, milestones, clean layout, sticky checkout
  
  CONFIGURATIE - pas deze waarden aan:
{% endcomment %}

{%- liquid
  assign free_shipping_threshold = 3995
  assign gift_threshold = 0
  assign gift_label = ""
  assign shipping_cost_cents = 495
  assign shipping_cost_display = "€4,95"

  assign cart_total = cart.total_price
  assign remaining_for_shipping = free_shipping_threshold | minus: cart_total
  if remaining_for_shipping < 0
    assign remaining_for_shipping = 0
  endif
  assign progress_pct = cart_total | times: 100 | divided_by: free_shipping_threshold
  if progress_pct > 100
    assign progress_pct = 100
  endif
  assign free_shipping_reached = false
  if cart_total >= free_shipping_threshold
    assign free_shipping_reached = true
  endif
  assign gift_reached = false
  if gift_threshold > 0 and cart_total >= gift_threshold
    assign gift_reached = true
  endif
-%}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer { visibility: hidden; }

  /* Progress bar */
  .cd-progress { padding: 16px 0 12px; border-bottom: 1px solid rgba(18,18,18,0.08); }
  .cd-progress__text { font-size: 13px; font-weight: 600; margin: 0 0 10px; text-align: center; }
  .cd-progress__text span { font-weight: 700; }
  .cd-progress__bar { height: 6px; background: #f0f0f0; border-radius: 3px; overflow: hidden; position: relative; }
  .cd-progress__fill { height: 100%; background: #121212; border-radius: 3px; transition: width 0.4s ease; }
  .cd-progress--done .cd-progress__fill { background: #2eae4e; }
  .cd-progress__milestones { display: flex; gap: 8px; margin-top: 10px; }
  .cd-milestone { display: flex; align-items: center; gap: 6px; font-size: 12px; padding: 6px 10px; border-radius: 6px; border: 1px solid rgba(18,18,18,0.1); flex: 1; }
  .cd-milestone--reached { background: #f0faf3; border-color: #2eae4e; }
  .cd-milestone--reached .cd-milestone__icon { color: #2eae4e; }
  .cd-milestone__icon { width: 16px; height: 16px; flex-shrink: 0; display: flex; }
  .cd-milestone__icon svg { width: 100%; height: 100%; }
  .cd-milestone__label { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .cd-milestone select { font-size: 11px; border: none; background: none; padding: 0; margin: 0; cursor: pointer; appearance: none; }

  /* Cart items enhanced */
  .cd-items { flex: 1; overflow-y: auto; padding: 0; }
  .cd-item { display: flex; gap: 14px; padding: 16px 0; border-bottom: 1px solid rgba(18,18,18,0.06); }
  .cd-item:last-child { border-bottom: none; }
  .cd-item__img { width: 72px; height: 72px; border-radius: 8px; overflow: hidden; flex-shrink: 0; background: #f5f5f5; }
  .cd-item__img img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .cd-item__info { flex: 1; display: flex; flex-direction: column; gap: 2px; min-width: 0; }
  .cd-item__title { font-size: 14px; font-weight: 600; margin: 0; line-height: 1.3; }
  .cd-item__title a { text-decoration: none; color: inherit; }
  .cd-item__variant { font-size: 12px; opacity: 0.55; margin: 0; }
  .cd-item__price-row { display: flex; align-items: center; justify-content: space-between; margin-top: auto; }
  .cd-item__price { font-size: 14px; font-weight: 700; }
  .cd-item__price s { font-weight: 400; opacity: 0.5; margin-right: 4px; }
  .cd-item__qty { display: flex; align-items: center; border: 1px solid rgba(18,18,18,0.15); border-radius: 6px; overflow: hidden; }
  .cd-item__qty button { width: 30px; height: 30px; border: none; background: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; color: #121212; padding: 0; }
  .cd-item__qty button:hover { background: #f5f5f5; }
  .cd-item__qty input { width: 28px; text-align: center; border: none; font-size: 13px; font-weight: 600; background: none; padding: 0; -moz-appearance: textfield; }
  .cd-item__qty input::-webkit-inner-spin-button, .cd-item__qty input::-webkit-outer-spin-button { -webkit-appearance: none; }
  .cd-item__remove { font-size: 12px; text-decoration: underline; color: inherit; opacity: 0.5; background: none; border: none; cursor: pointer; padding: 0; margin-top: 2px; align-self: flex-start; }
  .cd-item__remove:hover { opacity: 1; }
  .cd-item__discounts { margin: 2px 0 0; padding: 0; list-style: none; }
  .cd-item__discounts li { font-size: 11px; color: #2eae4e; display: flex; align-items: center; gap: 4px; }

  /* Footer */
  .cd-footer { border-top: 1px solid rgba(18,18,18,0.1); padding: 16px 0 0; }
  .cd-footer__row { display: flex; justify-content: space-between; align-items: center; font-size: 13px; margin-bottom: 6px; }
  .cd-footer__row--total { font-size: 15px; font-weight: 700; margin-bottom: 12px; margin-top: 4px; }
  .cd-footer__shipping { opacity: 0.6; }
  .cd-footer__shipping--free { color: #2eae4e; opacity: 1; font-weight: 600; }
  .cd-footer__tax { font-size: 11px; opacity: 0.45; margin: 0 0 14px; }
  .cd-checkout-btn { width: 100%; padding: 14px; font-size: 15px; font-weight: 700; border: none; border-radius: 8px; cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px; background: #121212; color: #fff; transition: background 0.2s; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.04em; }
  .cd-checkout-btn:hover { background: #333; }
  .cd-checkout-btn:disabled { opacity: 0.4; cursor: not-allowed; }

  /* Keep existing drawer structure working */
  .cart-drawer__form { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
  .drawer__contents.js-contents { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
  .drawer__cart-items-wrapper { overflow: hidden; display: flex; flex-direction: column; flex: 1; }

  /* Hide default table styling for our enhanced items */
  .cd-enhanced .cart-items { border: none; }
  .cd-enhanced .cart-items thead { display: none; }
  .cd-enhanced .cart-items tbody { display: flex; flex-direction: column; }
  .cd-enhanced .cart-items tr { display: contents; }
  .cd-enhanced .cart-items td { display: none; }

  /* Cart note styling */
  .cd-note-toggle { font-size: 12px; opacity: 0.5; background: none; border: none; cursor: pointer; padding: 8px 0; text-decoration: underline; }
</style>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>
            </div>
          </div>
          {%- if settings.cart_drawer_collection != blank -%}
            <div class="cart-drawer__collection">
              {% render 'card-collection', card_collection: settings.cart_drawer_collection, columns: 1 %}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} HEADER {%- endcomment -%}
      <div class="drawer__header">
        <h2 class="drawer__heading" style="text-transform:uppercase;font-size:14px;letter-spacing:0.06em;">WINKELMANDJE</h2>
        <button
          class="drawer__close"
          type="button"
          onclick="this.closest('cart-drawer').close()"
          aria-label="{{ 'accessibility.close' | t }}"
        >
          <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      {%- comment -%} PROGRESS BAR {%- endcomment -%}
      {%- if cart != empty and free_shipping_threshold > 0 -%}
        <div class="cd-progress{% if free_shipping_reached %} cd-progress--done{% endif %}">
          {%- if free_shipping_reached -%}
            <p class="cd-progress__text" style="color:#2eae4e;">Je hebt gratis verzending!</p>
          {%- else -%}
            <p class="cd-progress__text">Nog <span>{{ remaining_for_shipping | money }}</span> tot gratis verzending</p>
          {%- endif -%}
          <div class="cd-progress__bar">
            <div class="cd-progress__fill" style="width: {{ progress_pct }}%;"></div>
          </div>
          <div class="cd-progress__milestones">
            <div class="cd-milestone{% if free_shipping_reached %} cd-milestone--reached{% endif %}">
              <span class="cd-milestone__icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              </span>
              <span class="cd-milestone__label">{{ free_shipping_threshold | money }} - Gratis verzending</span>
            </div>
            {%- if gift_threshold > 0 -%}
              <div class="cd-milestone{% if gift_reached %} cd-milestone--reached{% endif %}">
                <span class="cd-milestone__icon">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                </span>
                <span class="cd-milestone__label">{{ gift_threshold | money }} - {{ gift_label | default: 'Cadeautje' }}</span>
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} CART ITEMS {%- endcomment -%}
      <cart-drawer-items {% if cart == empty %}class=" is-empty"{% endif %}>
        <form
          action="{{ routes.cart_url }}"
          id="CartDrawer-Form"
          class="cart__contents cart-drawer__form"
          method="post"
        >
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper cd-enhanced">
                {%- comment -%} Hidden table for Dawn JS compatibility {%- endcomment -%}
                <table class="cart-items" role="table" style="display:none;">
                  <thead role="rowgroup"><tr role="row">
                    <th id="CartDrawer-ColumnProductImage" role="columnheader"><span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span></th>
                    <th id="CartDrawer-ColumnProduct" role="columnheader">{{ 'sections.cart.headings.product' | t }}</th>
                    <th id="CartDrawer-ColumnTotal" role="columnheader">{{ 'sections.cart.headings.total' | t }}</th>
                    <th id="CartDrawer-ColumnQuantity" role="columnheader"><span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span></th>
                  </tr></thead>
                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cart-item" role="row">
                        <td role="cell"></td><td role="cell"></td><td role="cell"></td>
                        <td role="cell">
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container">
                                <quantity-input class="quantity cart-quantity">
                                  <button class="quantity__button" name="minus" type="button"><span class="visually-hidden">-</span></button>
                                  <input class="quantity__input" type="number" data-quantity-variant-id="{{ item.variant.id }}" name="updates[]" value="{{ item.quantity }}" min="0" step="{{ item.variant.quantity_rule.increment }}" aria-label="Aantal" id="Drawer-quantity-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                                  <button class="quantity__button" name="plus" type="button"><span class="visually-hidden">+</span></button>
                                </quantity-input>
                              </div>
                              <cart-remove-button id="CartDrawer-Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                                <button type="button" class="button button--tertiary cart-remove-button" aria-label="Verwijder" data-variant-id="{{ item.variant.id }}"></button>
                              </cart-remove-button>
                            </div>
                            <div id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}" class="cart-item__error" role="alert">
                              <small class="cart-item__error-text"></small>
                            </div>
                          </quantity-popover>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>

                {%- comment -%} Visual cart items {%- endcomment -%}
                <div class="cd-items">
                  {%- for item in cart.items -%}
                    <div class="cd-item">
                      <div class="cd-item__img">
                        {%- if item.image -%}
                          <a href="{{ item.url }}" tabindex="-1">
                            <img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" loading="lazy" width="72" height="72">
                          </a>
                        {%- endif -%}
                      </div>
                      <div class="cd-item__info">
                        <h3 class="cd-item__title"><a href="{{ item.url }}">{{ item.product.title | escape }}</a></h3>
                        {%- unless item.product.has_only_default_variant -%}
                          <p class="cd-item__variant">
                            {%- for option in item.options_with_values -%}
                              {{ option.value }}{% unless forloop.last %} / {% endunless %}
                            {%- endfor -%}
                          </p>
                        {%- endunless -%}
                        {%- if item.selling_plan_allocation != null -%}
                          <p class="cd-item__variant">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                        {%- endif -%}

                        {%- if item.line_level_discount_allocations.size > 0 -%}
                          <ul class="cd-item__discounts">
                            {%- for discount in item.line_level_discount_allocations -%}
                              <li>{{ discount.discount_application.title }}</li>
                            {%- endfor -%}
                          </ul>
                        {%- endif -%}

                        <div class="cd-item__price-row">
                          <div class="cd-item__qty">
                            <button type="button" aria-label="Minder" data-cd-minus="{{ item.index | plus: 1 }}">-</button>
                            <input type="number" value="{{ item.quantity }}" readonly aria-label="Aantal">
                            <button type="button" aria-label="Meer" data-cd-plus="{{ item.index | plus: 1 }}">+</button>
                          </div>
                          <div class="cd-item__price">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <s>{{ item.original_line_price | money }}</s>
                            {%- endif -%}
                            {{ item.final_line_price | money }}
                          </div>
                        </div>
                        <button type="button" class="cd-item__remove" data-cd-remove="{{ item.index | plus: 1 }}">Verwijderen</button>
                      </div>
                    </div>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {%- comment -%} FOOTER {%- endcomment -%}
      <div class="drawer__footer">
        <div class="cd-footer">
          {%- if cart.cart_level_discount_applications.size > 0 -%}
            {%- for discount in cart.cart_level_discount_applications -%}
              <div class="cd-footer__row" style="color:#2eae4e;">
                <span>{{ discount.title | escape }}</span>
                <span>-{{ discount.total_allocated_amount | money }}</span>
              </div>
            {%- endfor -%}
          {%- endif -%}

          <div class="cd-footer__row">
            <span>SUBTOTAAL</span>
            <span style="font-weight:600;">{{ cart.total_price | money }}</span>
          </div>
          <div class="cd-footer__row">
            <span>BEZORGKOSTEN</span>
            {%- if free_shipping_reached -%}
              <span class="cd-footer__shipping--free">Gratis</span>
            {%- else -%}
              <span class="cd-footer__shipping">{{ shipping_cost_display }}</span>
            {%- endif -%}
          </div>

          <button
            type="submit"
            id="CartDrawer-Checkout"
            class="cd-checkout-btn"
            name="checkout"
            form="CartDrawer-Form"
            {% if cart == empty %}disabled{% endif %}
          >
            <span>Nu afrekenen</span>
            <span>{{ cart.total_price | money }}</span>
          </button>

          <p class="cd-footer__tax">
            {%- if cart.taxes_included -%}
              Inclusief BTW.
            {%- else -%}
              Exclusief BTW. Berekend bij afrekenen.
            {%- endif -%}
          </p>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  /* Enhanced cart drawer: sync visual qty buttons with Dawn's hidden quantity-input system */
  document.addEventListener('DOMContentLoaded', function() {
    var drawer = document.querySelector('cart-drawer');
    if (!drawer) return;

    function findHiddenInput(index) {
      return document.getElementById('Drawer-quantity-' + index);
    }
    function triggerChange(input) {
      input.dispatchEvent(new Event('change', { bubbles: true }));
    }

    drawer.addEventListener('click', function(e) {
      var minusBtn = e.target.closest('[data-cd-minus]');
      var plusBtn = e.target.closest('[data-cd-plus]');
      var removeBtn = e.target.closest('[data-cd-remove]');

      if (minusBtn) {
        var idx = minusBtn.dataset.cdMinus;
        var input = findHiddenInput(idx);
        if (input) {
          var step = parseInt(input.step) || 1;
          var newVal = parseInt(input.value) - step;
          input.value = Math.max(0, newVal);
          triggerChange(input);
        }
      }
      if (plusBtn) {
        var idx = plusBtn.dataset.cdPlus;
        var input = findHiddenInput(idx);
        if (input) {
          var step = parseInt(input.step) || 1;
          var max = input.max ? parseInt(input.max) : Infinity;
          var newVal = parseInt(input.value) + step;
          input.value = Math.min(max, newVal);
          triggerChange(input);
        }
      }
      if (removeBtn) {
        var idx = removeBtn.dataset.cdRemove;
        var input = findHiddenInput(idx);
        if (input) {
          input.value = 0;
          triggerChange(input);
        }
      }
    });
  });
</script>
