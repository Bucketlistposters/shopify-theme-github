{% comment %}
  Enhanced Cart Drawer - Upfront style
  CONFIGURATIE:
  - free_shipping_threshold: bedrag in centen (3995 = €39,95)
  - shipping_cost_display: tekst voor verzendkosten
{% endcomment %}

{%- liquid
  assign free_shipping_threshold = 3995
  assign shipping_cost_display = "€4,95"

  assign cart_total = cart.total_price
  assign remaining_for_shipping = free_shipping_threshold | minus: cart_total
  if remaining_for_shipping < 0
    assign remaining_for_shipping = 0
  endif
  assign progress_pct = cart_total | times: 100 | divided_by: free_shipping_threshold
  if progress_pct > 100
    assign progress_pct = 100
  endif
  assign free_shipping_reached = false
  if cart_total >= free_shipping_threshold
    assign free_shipping_reached = true
  endif
-%}

{{ 'quantity-popover.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}

<script src="{{ 'cart.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>

<style>
  .drawer {
    visibility: hidden;
  }

  /* ===== DRAWER SIZING & OVERLAY ===== */
  .cart-drawer__overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    z-index: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .drawer.active .cart-drawer__overlay {
    opacity: 1;
  }

  .drawer__inner {
    width: 50rem !important;
    max-width: calc(100vw - 1rem) !important;
    z-index: 2;
    position: relative;
  }

  @media screen and (max-width: 749px) {
    .drawer__inner {
      width: 100vw !important;
      max-width: 100vw !important;
    }
  }

  /* ===== HEADER ===== */
  .cd-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 0;
    border-bottom: 1px solid rgba(18, 18, 18, 0.08);
  }

  .cd-header__title {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .cd-header__close {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    color: inherit;
  }

  .cd-header__close svg {
    width: 20px;
    height: 20px;
  }

  /* ===== PROGRESS BAR ===== */
  .cd-progress {
    padding: 16px 0;
    border-bottom: 1px solid rgba(18, 18, 18, 0.08);
  }

  .cd-progress__text {
    font-size: 13px;
    font-weight: 600;
    margin: 0 0 10px;
    text-align: center;
  }

  .cd-progress__text--done {
    color: #2eae4e;
  }

  .cd-progress__bar-wrap {
    height: 8px;
    background: #e8e8e8;
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }

  .cd-progress__bar-fill {
    height: 100%;
    border-radius: 4px;
    transition: width 0.5s ease;
    background: #121212;
    min-width: 4px;
  }

  .cd-progress--done .cd-progress__bar-fill {
    background: #2eae4e;
  }

  .cd-progress__milestone {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    padding: 8px 12px;
    border-radius: 8px;
    border: 1px solid rgba(18, 18, 18, 0.1);
    margin-top: 12px;
    background: #fafafa;
  }

  .cd-progress__milestone--reached {
    background: #f0faf3;
    border-color: #2eae4e;
    color: #2eae4e;
  }

  .cd-progress__milestone svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* ===== CART ITEMS ===== */
  .cd-items-scroll {
    flex: 1;
    overflow-y: auto;
    padding: 4px 0;
  }

  /* Hide the default Dawn table headers */
  .cd-items-scroll .cart-items thead {
    display: none;
  }

  .cd-items-scroll .cart-items {
    border-spacing: 0;
    width: 100%;
    border: none;
  }

  .cd-items-scroll .cart-items tbody {
    display: block;
  }

  /* Restyle each cart item row */
  .cd-items-scroll .cart-item {
    display: flex !important;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 0;
    border-bottom: 1px solid rgba(18, 18, 18, 0.06);
  }

  .cd-items-scroll .cart-item:last-child {
    border-bottom: none;
  }

  /* Image cell */
  .cd-items-scroll .cart-item__media {
    display: block !important;
    width: 80px;
    flex-shrink: 0;
    padding: 0 !important;
  }

  .cd-items-scroll .cart-item__image {
    width: 80px !important;
    height: 80px !important;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  /* Details cell */
  .cd-items-scroll .cart-item__details {
    display: block !important;
    flex: 1;
    padding: 0 !important;
    min-width: 0;
  }

  .cd-items-scroll .cart-item__name {
    font-size: 14px !important;
    font-weight: 600;
    line-height: 1.3;
    margin-bottom: 2px;
    display: block;
  }

  .cd-items-scroll .product-option {
    font-size: 12px;
    opacity: 0.55;
  }

  /* Totals cell */
  .cd-items-scroll .cart-item__totals {
    display: block !important;
    padding: 0 !important;
    flex-shrink: 0;
    text-align: right;
  }

  .cd-items-scroll .cart-item__totals .price {
    font-size: 14px;
    font-weight: 700;
  }

  /* Quantity cell */
  .cd-items-scroll .cart-item__quantity {
    display: block !important;
    padding: 0 !important;
    width: 100%;
  }

  .cd-items-scroll .cart-item__quantity-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 6px;
  }

  .cd-items-scroll .quantity.cart-quantity {
    display: flex;
    align-items: center;
    border: 1px solid rgba(18, 18, 18, 0.15);
    border-radius: 6px;
    overflow: hidden;
  }

  .cd-items-scroll .quantity__button {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }

  .cd-items-scroll .quantity__button:hover {
    background: #f5f5f5;
  }

  .cd-items-scroll .quantity__input {
    width: 32px;
    text-align: center;
    border: none;
    font-size: 13px;
    font-weight: 600;
    background: none;
    padding: 0;
    height: 32px;
    -moz-appearance: textfield;
  }

  .cd-items-scroll .quantity__input::-webkit-inner-spin-button,
  .cd-items-scroll .quantity__input::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  .cd-items-scroll .cart-remove-button {
    font-size: 12px;
    text-decoration: underline;
    opacity: 0.45;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    min-height: 0;
  }

  .cd-items-scroll .cart-remove-button:hover {
    opacity: 1;
  }

  .cd-items-scroll .cart-remove-button .svg-wrapper {
    display: none;
  }

  .cd-items-scroll .cart-remove-button::after {
    content: 'Verwijderen';
  }

  /* Discounts */
  .cd-items-scroll .discounts {
    margin-top: 4px;
  }

  .cd-items-scroll .discounts__discount {
    font-size: 11px;
    color: #2eae4e;
  }

  /* Hide volume pricing popover clutter */
  .cd-items-scroll .quantity-popover__info-button,
  .cd-items-scroll .quantity-popover__info {
    display: none;
  }

  /* Error messages */
  .cd-items-scroll .cart-item__error {
    margin-top: 4px;
  }

  .cd-items-scroll .cart-item__error-text:not(:empty) {
    font-size: 12px;
    color: #cc0000;
    display: block;
  }

  /* ===== FOOTER ===== */
  .cd-footer {
    border-top: 1px solid rgba(18, 18, 18, 0.1);
    padding: 16px 0 8px;
    flex-shrink: 0;
  }

  .cd-footer__row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    margin-bottom: 6px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cd-footer__val {
    font-weight: 600;
  }

  .cd-footer__free {
    color: #2eae4e;
    font-weight: 700;
  }

  .cd-checkout-btn {
    width: 100%;
    padding: 16px;
    font-size: 15px;
    font-weight: 700;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #121212;
    color: #fff;
    transition: background 0.2s;
    margin-top: 10px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cd-checkout-btn:hover {
    background: #333;
  }

  .cd-checkout-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .cd-footer__tax {
    font-size: 11px;
    opacity: 0.4;
    margin: 10px 0 0;
    text-transform: none;
    letter-spacing: 0;
  }

  /* ===== HIDE DEFAULT DAWN HEADER/FOOTER ===== */
  .drawer__header,
  .drawer__footer .cart-drawer__footer,
  .drawer__footer .cart__ctas,
  .drawer__footer details#Details-CartDrawer {
    display: none !important;
  }

  .drawer__footer {
    padding: 0 !important;
    margin: 0 !important;
    border: none !important;
  }

  /* Cart form layout */
  .cart-drawer__form {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
  }

  .drawer__contents.js-contents {
    display: flex;
    flex-direction: column;
    flex: 1;
    overflow: hidden;
  }

  .drawer__cart-items-wrapper {
    flex: 1;
    overflow-y: auto;
    display: block;
  }

  /* ===== ADD-TO-CART TOAST ===== */
  .cd-toast {
    position: fixed;
    top: 16px;
    right: 16px;
    z-index: 10000;
    background: #121212;
    color: #fff;
    padding: 14px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 10px;
    transform: translateY(-20px);
    opacity: 0;
    transition: all 0.3s ease;
    pointer-events: none;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2);
  }

  .cd-toast.is-visible {
    transform: translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .cd-toast svg {
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .cd-toast__close {
    background: none;
    border: none;
    color: #fff;
    cursor: pointer;
    padding: 0;
    margin-left: 8px;
    opacity: 0.6;
  }

  .cd-toast__close:hover {
    opacity: 1;
  }
</style>

{%- comment -%} ADD-TO-CART TOAST {%- endcomment -%}
<div class="cd-toast" id="CdToast">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
  <span id="CdToastText">Toegevoegd aan winkelmandje</span>
  <button class="cd-toast__close" onclick="document.getElementById('CdToast').classList.remove('is-visible')">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
  </button>
</div>

<cart-drawer class="drawer{% if cart == empty %} is-empty{% endif %}">
  <div id="CartDrawer" class="cart-drawer">
    <div id="CartDrawer-Overlay" class="cart-drawer__overlay"></div>
    <div
      class="drawer__inner gradient color-{{ settings.cart_color_scheme }}"
      role="dialog"
      aria-modal="true"
      aria-label="{{ 'sections.cart.title' | t }}"
      tabindex="-1"
    >
      {%- if cart == empty -%}
        <div class="drawer__inner-empty">
          <div class="cart-drawer__warnings center{% if settings.cart_drawer_collection != blank %} cart-drawer__warnings--has-collection{% endif %}">
            <div class="cart-drawer__empty-content">
              <h2 class="cart__empty-text">{{ 'sections.cart.empty' | t }}</h2>
              <button
                class="drawer__close"
                type="button"
                onclick="this.closest('cart-drawer').close()"
                aria-label="{{ 'accessibility.close' | t }}"
              >
                <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
              </button>
              <a href="{{ routes.all_products_collection_url }}" class="button">
                {{ 'general.continue_shopping' | t }}
              </a>
            </div>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ===== CUSTOM HEADER ===== {%- endcomment -%}
      <div class="cd-header">
        <h2 class="cd-header__title">WINKELMANDJE</h2>
        <button class="cd-header__close" type="button" onclick="this.closest('cart-drawer').close()" aria-label="Sluiten">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      {%- comment -%} ===== DEFAULT HEADER (hidden by CSS, needed for JS) ===== {%- endcomment -%}
      <div class="drawer__header">
        <h2 class="drawer__heading">{{ 'sections.cart.title' | t }}</h2>
        <button class="drawer__close" type="button" onclick="this.closest('cart-drawer').close()" aria-label="{{ 'accessibility.close' | t }}">
          <span class="svg-wrapper">{{- 'icon-close.svg' | inline_asset_content -}}</span>
        </button>
      </div>

      {%- comment -%} ===== PROGRESS BAR ===== {%- endcomment -%}
      {%- if cart != empty and free_shipping_threshold > 0 -%}
        <div class="cd-progress{% if free_shipping_reached %} cd-progress--done{% endif %}">
          {%- if free_shipping_reached -%}
            <p class="cd-progress__text cd-progress__text--done">Je hebt gratis verzending!</p>
          {%- else -%}
            <p class="cd-progress__text">Nog <strong>{{ remaining_for_shipping | money }}</strong> tot gratis verzending</p>
          {%- endif -%}
          <div class="cd-progress__bar-wrap">
            <div class="cd-progress__bar-fill" style="width: {{ progress_pct }}%;"></div>
          </div>
          <div class="cd-progress__milestone{% if free_shipping_reached %} cd-progress__milestone--reached{% endif %}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>{{ free_shipping_threshold | money }} - Gratis verzending</span>
          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ===== CART ITEMS (Dawn's actual structure, restyled with CSS) ===== {%- endcomment -%}
      <cart-drawer-items {% if cart == empty %}class=" is-empty"{% endif %}>
        <form action="{{ routes.cart_url }}" id="CartDrawer-Form" class="cart__contents cart-drawer__form" method="post">
          <div id="CartDrawer-CartItems" class="drawer__contents js-contents">
            {%- if cart != empty -%}
              <div class="drawer__cart-items-wrapper cd-items-scroll">
                <table class="cart-items" role="table">
                  <thead role="rowgroup">
                    <tr role="row">
                      <th id="CartDrawer-ColumnProductImage" role="columnheader"><span class="visually-hidden">{{ 'sections.cart.headings.image' | t }}</span></th>
                      <th id="CartDrawer-ColumnProduct" class="caption-with-letter-spacing" scope="col" role="columnheader">{{ 'sections.cart.headings.product' | t }}</th>
                      <th id="CartDrawer-ColumnTotal" class="right caption-with-letter-spacing" scope="col" role="columnheader">{{ 'sections.cart.headings.total' | t }}</th>
                      <th id="CartDrawer-ColumnQuantity" role="columnheader"><span class="visually-hidden">{{ 'sections.cart.headings.quantity' | t }}</span></th>
                    </tr>
                  </thead>
                  <tbody role="rowgroup">
                    {%- for item in cart.items -%}
                      <tr id="CartDrawer-Item-{{ item.index | plus: 1 }}" class="cart-item" role="row">
                        <td class="cart-item__media" role="cell" headers="CartDrawer-ColumnProductImage">
                          {% if item.image %}
                            <a href="{{ item.url }}" class="cart-item__link" tabindex="-1" aria-hidden="true"> </a>
                            <img class="cart-item__image" src="{{ item.image | image_url: width: 300 }}" alt="{{ item.image.alt | escape }}" loading="lazy" width="150" height="{{ 150 | divided_by: item.image.aspect_ratio | ceil }}">
                          {% endif %}
                        </td>
                        <td class="cart-item__details" role="cell" headers="CartDrawer-ColumnProduct">
                          <a href="{{ item.url }}" class="cart-item__name h4 break">{{ item.product.title | escape }}</a>
                          {%- if item.original_price != item.final_price -%}
                            <div class="cart-item__discounted-prices">
                              <s class="cart-item__old-price product-option">{{ item.original_price | money }}</s>
                              <strong class="cart-item__final-price product-option">{{ item.final_price | money }}</strong>
                            </div>
                          {%- else -%}
                            <div class="product-option">{{ item.original_price | money }}</div>
                          {%- endif -%}
                          {%- unless item.product.has_only_default_variant -%}
                            <dl>
                              {%- for option in item.options_with_values -%}
                                <div class="product-option"><dt>{{ option.name }}:</dt><dd>{{ option.value }}</dd></div>
                              {%- endfor -%}
                            </dl>
                          {%- endunless -%}
                          {%- if item.selling_plan_allocation != null -%}
                            <p class="product-option">{{ item.selling_plan_allocation.selling_plan.name }}</p>
                          {%- endif -%}
                          <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                            {%- for discount in item.line_level_discount_allocations -%}
                              <li class="discounts__discount">{{- 'icon-discount.svg' | inline_asset_content -}}{{ discount.discount_application.title }}</li>
                            {%- endfor -%}
                          </ul>
                        </td>
                        <td class="cart-item__totals right" role="cell" headers="CartDrawer-ColumnTotal">
                          {%- render 'loading-spinner' -%}
                          <div class="cart-item__price-wrapper">
                            {%- if item.original_line_price != item.final_line_price -%}
                              <div class="cart-item__discounted-prices">
                                <s class="cart-item__old-price price price--end">{{ item.original_line_price | money }}</s>
                                <span class="price price--end">{{ item.final_line_price | money }}</span>
                              </div>
                            {%- else -%}
                              <span class="price price--end">{{ item.original_line_price | money }}</span>
                            {%- endif -%}
                          </div>
                        </td>
                        <td class="cart-item__quantity" role="cell" headers="CartDrawer-ColumnQuantity">
                          <quantity-popover>
                            <div class="cart-item__quantity-wrapper quantity-popover-wrapper">
                              <div class="quantity-popover-container">
                                <quantity-input class="quantity cart-quantity">
                                  <button class="quantity__button" name="minus" type="button">
                                    <span class="visually-hidden">{{ 'products.product.quantity.decrease' | t: product: item.product.title | escape }}</span>
                                    <span class="svg-wrapper">{{- 'icon-minus.svg' | inline_asset_content -}}</span>
                                  </button>
                                  <input class="quantity__input" type="number" data-quantity-variant-id="{{ item.variant.id }}" name="updates[]" value="{{ item.quantity }}" {% comment %}theme-check-disable{% endcomment %}data-cart-quantity="{{ cart | item_count_for_variant: item.variant.id }}" min="0" data-min="{{ item.variant.quantity_rule.min }}" {% if item.variant.quantity_rule.max != null %}max="{{ item.variant.quantity_rule.max }}"{% endif %} step="{{ item.variant.quantity_rule.increment }}" {% comment %}theme-check-enable{% endcomment %} aria-label="{{ 'products.product.quantity.input_label' | t: product: item.product.title | escape }}" id="Drawer-quantity-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                                  <button class="quantity__button" name="plus" type="button">
                                    <span class="visually-hidden">{{ 'products.product.quantity.increase' | t: product: item.product.title | escape }}</span>
                                    <span class="svg-wrapper">{{- 'icon-plus.svg' | inline_asset_content -}}</span>
                                  </button>
                                </quantity-input>
                              </div>
                              <cart-remove-button id="CartDrawer-Remove-{{ item.index | plus: 1 }}" data-index="{{ item.index | plus: 1 }}">
                                <button type="button" class="button button--tertiary cart-remove-button" aria-label="{{ 'sections.cart.remove_title' | t: title: item.title | escape }}" data-variant-id="{{ item.variant.id }}">
                                  <span class="svg-wrapper">{{- 'icon-remove.svg' | inline_asset_content -}}</span>
                                </button>
                              </cart-remove-button>
                            </div>
                            <div id="CartDrawer-LineItemError-{{ item.index | plus: 1 }}" class="cart-item__error" role="alert">
                              <small class="cart-item__error-text"></small>
                              <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                            </div>
                          </quantity-popover>
                        </td>
                      </tr>
                    {%- endfor -%}
                  </tbody>
                </table>
              </div>
            {%- endif -%}
            <p id="CartDrawer-LiveRegionText" class="visually-hidden" role="status"></p>
            <p id="CartDrawer-LineItemStatus" class="visually-hidden" aria-hidden="true" role="status">{{ 'accessibility.loading' | t }}</p>
          </div>
          <div id="CartDrawer-CartErrors" role="alert"></div>
        </form>
      </cart-drawer-items>

      {%- comment -%} ===== CUSTOM FOOTER ===== {%- endcomment -%}
      <div class="cd-footer">
        {%- if cart.cart_level_discount_applications.size > 0 -%}
          {%- for discount in cart.cart_level_discount_applications -%}
            <div class="cd-footer__row" style="color:#2eae4e;">
              <span>{{ discount.title | escape }}</span>
              <span>-{{ discount.total_allocated_amount | money }}</span>
            </div>
          {%- endfor -%}
        {%- endif -%}
        <div class="cd-footer__row">
          <span>SUBTOTAAL</span>
          <span class="cd-footer__val">{{ cart.total_price | money }}</span>
        </div>
        <div class="cd-footer__row">
          <span>BEZORGKOSTEN</span>
          {%- if free_shipping_reached -%}
            <span class="cd-footer__free">Gratis</span>
          {%- else -%}
            <span class="cd-footer__val" style="opacity:0.55;">{{ shipping_cost_display }}</span>
          {%- endif -%}
        </div>
        <button type="submit" id="CartDrawer-Checkout" class="cd-checkout-btn" name="checkout" form="CartDrawer-Form" {% if cart == empty %}disabled{% endif %}>
          <span>NU AFREKENEN</span>
          <span>{{ cart.total_price | money }}</span>
        </button>
        <p class="cd-footer__tax">
          {%- if cart.taxes_included -%}Inclusief BTW{%- else -%}Exclusief BTW, berekend bij afrekenen{%- endif -%}
        </p>
      </div>

      {%- comment -%} ===== DEFAULT FOOTER (hidden by CSS, keeps Dawn JS working) ===== {%- endcomment -%}
      <div class="drawer__footer">
        <div class="cart-drawer__footer">
          <div class="totals" role="status">
            <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2>
            <p class="totals__total-value">{{ cart.total_price | money_with_currency }}</p>
          </div>
        </div>
        <div class="cart__ctas">
          <button type="submit" id="CartDrawer-Checkout-Hidden" class="cart__checkout-button button" name="checkout" form="CartDrawer-Form" {% if cart == empty %}disabled{% endif %}>
            {{ 'sections.cart.checkout' | t }}
          </button>
        </div>
      </div>
    </div>
  </div>
</cart-drawer>

<script>
  /* Toast notification on add-to-cart */
  (function() {
    var origOpen = CartDrawer.prototype.open;
    if (!origOpen) return;

    CartDrawer.prototype.open = function(triggeredBy) {
      var toast = document.getElementById('CdToast');
      if (toast && triggeredBy && triggeredBy.id !== 'cart-icon-bubble') {
        toast.classList.add('is-visible');
        setTimeout(function() { toast.classList.remove('is-visible'); }, 2500);
      }
      return origOpen.call(this, triggeredBy);
    };
  })();
</script>
