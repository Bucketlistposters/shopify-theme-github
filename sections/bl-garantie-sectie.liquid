{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .gs-{{ section.id }} .gs-wrapper {
    display: flex;
    flex-direction: column-reverse;
    gap: 32px;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .gs-{{ section.id }} .gs-wrapper {
      flex-direction: row;
      gap: 48px;
    }
    .gs-{{ section.id }} .gs-wrapper--reversed { flex-direction: row-reverse; }
  }

  .gs-{{ section.id }} .gs-content { flex: 1; }

  .gs-{{ section.id }} .gs-heading { margin: 0 0 16px; line-height: 1.2; }

  .gs-{{ section.id }} .gs-text {
    font-size: 15px; line-height: 1.7; opacity: 0.75; margin: 0 0 24px;
  }

  .gs-{{ section.id }} .gs-image-wrap {
    flex: 0 0 100%; width: 100%; max-width: 400px;
    border-radius: {{ section.settings.image_radius }}px; overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    .gs-{{ section.id }} .gs-image-wrap { flex: 0 0 40%; max-width: none; }
  }

  .gs-{{ section.id }} .gs-image-wrap img {
    width: 100%; height: auto; display: block; object-fit: cover;
  }

  .gs-{{ section.id }} .gs-checks {
    list-style: none; padding: 0; margin: 0 0 24px;
    display: flex; flex-direction: column; gap: 10px;
  }

  .gs-{{ section.id }} .gs-check {
    display: flex; align-items: center; gap: 10px;
    font-size: 14px; font-weight: 500;
  }

  .gs-{{ section.id }} .gs-check-icon {
    flex-shrink: 0; width: 22px; height: 22px; border-radius: 50%;
    background: {{ section.settings.check_color }};
    display: flex; align-items: center; justify-content: center;
  }
  .gs-{{ section.id }} .gs-check-icon svg {
    width: 12px; height: 12px; stroke: #fff; fill: none;
    stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding gs-{{ section.id }}">
    <div class="gs-wrapper{% if section.settings.image_position == 'right' %} gs-wrapper--reversed{% endif %}">
      {%- if section.settings.image != blank -%}
        <div class="gs-image-wrap">
          <img src="{{ section.settings.image | image_url: width: 800 }}" alt="{{ section.settings.heading | strip_html | escape }}" loading="lazy" width="{{ section.settings.image.width }}" height="{{ section.settings.image.height }}">
        </div>
      {%- endif -%}

      <div class="gs-content">
        {%- if section.settings.heading != blank -%}
          <h2 class="gs-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="gs-text rte">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.blocks.size > 0 -%}
          <ul class="gs-checks">
            {%- for block in section.blocks -%}
              <li class="gs-check" {{ block.shopify_attributes }}>
                <span class="gs-check-icon"><svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg></span>
                {{ block.settings.text | escape }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="button button--primary">{{ section.settings.button_label | escape }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "BL - Garantie Sectie",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Niet tevreden? Geen probleem!" },
    { "type": "select", "id": "heading_size", "options": [
      { "value": "h2", "label": "Small" },{ "value": "h1", "label": "Medium" },{ "value": "h0", "label": "Large" }
    ], "default": "h1", "label": "Heading grootte" },
    { "type": "richtext", "id": "text", "label": "Tekst", "default": "<p>We staan achter de kwaliteit van onze producten. Ben je toch niet tevreden? Dan regelen we het voor je.</p>" },
    { "type": "text", "id": "button_label", "label": "Knoptekst", "default": "Bestel nu" },
    { "type": "url", "id": "button_link", "label": "Knoplink" },
    { "type": "header", "content": "Afbeelding" },
    { "type": "image_picker", "id": "image", "label": "Afbeelding" },
    { "type": "select", "id": "image_position", "options": [
      { "value": "left", "label": "Links" },{ "value": "right", "label": "Rechts" }
    ], "default": "left", "label": "Afbeelding positie" },
    { "type": "range", "id": "image_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 12, "label": "Afbeelding border radius" },
    { "type": "header", "content": "Stijl" },
    { "type": "color", "id": "check_color", "label": "Vinkje kleur", "default": "#121212" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurenschema", "default": "scheme-1" },
    { "type": "header", "content": "Sectie padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding boven" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding onder" }
  ],
  "blocks": [
    {
      "type": "check_item",
      "name": "Checklijst item",
      "settings": [
        { "type": "text", "id": "text", "label": "Tekst", "default": "Gratis retourneren" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BL - Garantie Sectie",
      "blocks": [
        { "type": "check_item", "settings": { "text": "Gratis verzending" } },
        { "type": "check_item", "settings": { "text": "Niet goed? Geld terug" } },
        { "type": "check_item", "settings": { "text": "Veilig betalen" } }
      ]
    }
  ]
}
{% endschema %}
