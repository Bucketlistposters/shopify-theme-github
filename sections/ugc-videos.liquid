{{ 'component-slider.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ugc-videos-{{ section.id }} {
    overflow: hidden;
  }

  .ugc-videos-{{ section.id }} .ugc-title-wrapper {
    text-align: {{ section.settings.heading_alignment }};
    margin-bottom: 2rem;
  }

  .ugc-videos-{{ section.id }} .ugc-heading {
    margin: 0;
    font-size: inherit;
  }

  .ugc-videos-{{ section.id }} .ugc-subheading {
    margin: 0.5rem 0 0;
    opacity: 0.7;
  }

  .ugc-videos-{{ section.id }} .ugc-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: {{ section.settings.gap_mobile }}px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ugc-videos-{{ section.id }} .ugc-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
      gap: {{ section.settings.gap }}px;
    }
  }

  .ugc-videos-{{ section.id }} .ugc-video-item {
    position: relative;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    background: #000;
  }

  .ugc-videos-{{ section.id }} .ugc-video-item::before {
    content: '';
    display: block;
    padding-bottom: {{ section.settings.aspect_ratio }}%;
  }

  .ugc-videos-{{ section.id }} .ugc-video-item video,
  .ugc-videos-{{ section.id }} .ugc-video-item .ugc-poster {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ugc-videos-{{ section.id }} .ugc-poster {
    cursor: pointer;
    z-index: 1;
    transition: opacity 0.3s ease;
  }

  .ugc-videos-{{ section.id }} .ugc-poster.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ugc-videos-{{ section.id }} .ugc-play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 2;
    width: 56px;
    height: 56px;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.9);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
    padding: 0;
  }

  .ugc-videos-{{ section.id }} .ugc-play-btn:hover {
    background: #fff;
    transform: translate(-50%, -50%) scale(1.08);
  }

  .ugc-videos-{{ section.id }} .ugc-play-btn.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ugc-videos-{{ section.id }} .ugc-play-btn svg {
    width: 20px;
    height: 20px;
    margin-left: 3px;
    fill: #000;
  }

  .ugc-videos-{{ section.id }} .ugc-author {
    position: absolute;
    bottom: 12px;
    left: 12px;
    z-index: 3;
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    text-shadow: 0 1px 4px rgba(0,0,0,0.5);
    pointer-events: none;
  }

  .ugc-videos-{{ section.id }} .ugc-placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e8e8e8;
    color: #999;
    font-size: 14px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding ugc-videos-{{ section.id }}">
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="ugc-title-wrapper">
        {%- if section.settings.heading != blank -%}
          <h2 class="ugc-heading inline-richtext {{ section.settings.heading_size }}">
            {{ section.settings.heading }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="ugc-subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <ul class="ugc-grid">
      {%- for block in section.blocks -%}
        <li class="ugc-video-item" {{ block.shopify_attributes }}>
          {%- if block.settings.video != blank -%}
            <video
              src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
              playsinline
              {% if section.settings.loop %}loop{% endif %}
              {% if section.settings.muted %}muted{% endif %}
              preload="metadata"
              data-ugc-video
            ></video>

            {%- if block.settings.video.preview_image or block.settings.cover_image != blank -%}
              {%- assign poster_image = block.settings.cover_image | default: block.settings.video.preview_image -%}
              <img
                class="ugc-poster"
                src="{{ poster_image | image_url: width: 600 }}"
                alt="{{ block.settings.author | escape | default: 'UGC video' }}"
                loading="lazy"
                width="600"
                height="{{ 600 | divided_by: poster_image.aspect_ratio | ceil }}"
                data-ugc-poster
              >
            {%- endif -%}

            <button class="ugc-play-btn" aria-label="{{ 'sections.video.load_video' | t }}" data-ugc-play>
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 4l12 6-12 6V4z"/>
              </svg>
            </button>
          {%- elsif block.settings.video_url != blank -%}
            {%- assign cover = block.settings.cover_image -%}
            {%- if cover != blank -%}
              <img
                class="ugc-poster"
                src="{{ cover | image_url: width: 600 }}"
                alt="{{ block.settings.author | escape | default: 'UGC video' }}"
                loading="lazy"
                width="600"
                height="{{ 600 | divided_by: cover.aspect_ratio | ceil }}"
                data-ugc-poster
              >
            {%- else -%}
              <div class="ugc-placeholder" data-ugc-poster>Video</div>
            {%- endif -%}
            <button
              class="ugc-play-btn"
              aria-label="{{ 'sections.video.load_video' | t }}"
              data-ugc-play
              data-ugc-external-url="{{ block.settings.video_url }}"
              {%- if block.settings.video_url.type == 'youtube' -%}
                data-ugc-youtube="{{ block.settings.video_url.id }}"
              {%- elsif block.settings.video_url.type == 'vimeo' -%}
                data-ugc-vimeo="{{ block.settings.video_url.id }}"
              {%- endif -%}
            >
              <svg viewBox="0 0 20 20" xmlns="http://www.w3.org/2000/svg">
                <path d="M6 4l12 6-12 6V4z"/>
              </svg>
            </button>
          {%- else -%}
            <div class="ugc-placeholder">{{ 'sections.video.load_video' | t | default: 'Upload a video' }}</div>
          {%- endif -%}

          {%- if block.settings.author != blank -%}
            <span class="ugc-author">@{{ block.settings.author | escape }}</span>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    document.querySelectorAll('.ugc-videos-{{ section.id }} [data-ugc-play]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var item = btn.closest('.ugc-video-item');
        var video = item.querySelector('[data-ugc-video]');
        var poster = item.querySelector('[data-ugc-poster]');

        if (btn.dataset.ugcYoutube) {
          var iframe = document.createElement('iframe');
          iframe.src = 'https://www.youtube.com/embed/' + btn.dataset.ugcYoutube + '?autoplay=1';
          iframe.allow = 'autoplay; encrypted-media';
          iframe.allowFullscreen = true;
          iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:0;';
          item.appendChild(iframe);
          btn.classList.add('is-hidden');
          if (poster) poster.classList.add('is-hidden');
          return;
        }

        if (btn.dataset.ugcVimeo) {
          var iframe = document.createElement('iframe');
          iframe.src = 'https://player.vimeo.com/video/' + btn.dataset.ugcVimeo + '?autoplay=1';
          iframe.allow = 'autoplay; encrypted-media';
          iframe.allowFullscreen = true;
          iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:0;';
          item.appendChild(iframe);
          btn.classList.add('is-hidden');
          if (poster) poster.classList.add('is-hidden');
          return;
        }

        if (video) {
          if (video.paused) {
            video.play();
            btn.classList.add('is-hidden');
            if (poster) poster.classList.add('is-hidden');
          } else {
            video.pause();
            btn.classList.remove('is-hidden');
          }
        }
      });
    });

    document.querySelectorAll('.ugc-videos-{{ section.id }} [data-ugc-video]').forEach(function (video) {
      video.addEventListener('click', function () {
        var item = video.closest('.ugc-video-item');
        var btn = item.querySelector('[data-ugc-play]');
        if (!video.paused) {
          video.pause();
          if (btn) btn.classList.remove('is-hidden');
        } else {
          video.play();
          if (btn) btn.classList.add('is-hidden');
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "UGC Videos",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Onze community"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Bekijk hoe onze klanten onze producten gebruiken"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Heading alignment"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "label": "Columns desktop"
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2",
      "label": "Columns mobile"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16,
      "label": "Gap"
    },
    {
      "type": "range",
      "id": "gap_mobile",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8,
      "label": "Gap mobile"
    },
    {
      "type": "range",
      "id": "aspect_ratio",
      "min": 100,
      "max": 200,
      "step": 5,
      "unit": "%",
      "default": 165,
      "label": "Aspect ratio (height %)",
      "info": "165% = 9:16 portrait, 100% = square"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12,
      "label": "Border radius"
    },
    {
      "type": "header",
      "content": "Video settings"
    },
    {
      "type": "checkbox",
      "id": "muted",
      "default": true,
      "label": "Start muted"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "default": true,
      "label": "Loop videos"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36,
      "label": "Padding bottom"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "UGC Video",
      "settings": [
        {
          "type": "video",
          "id": "video",
          "label": "Shopify hosted video"
        },
        {
          "type": "video_url",
          "id": "video_url",
          "accept": ["youtube", "vimeo"],
          "label": "Or YouTube/Vimeo URL",
          "info": "Used if no Shopify video is uploaded"
        },
        {
          "type": "image_picker",
          "id": "cover_image",
          "label": "Cover image (optional)",
          "info": "Overrides the auto-generated preview"
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author / username",
          "info": "Shown in bottom left corner"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "UGC Videos",
      "blocks": [
        { "type": "video" },
        { "type": "video" },
        { "type": "video" },
        { "type": "video" }
      ]
    }
  ]
}
{% endschema %}
