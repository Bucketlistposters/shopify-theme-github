      "settings": {
        "custom_liquid": "<style>\n  .payment-icons {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 8px;\n    flex-wrap: wrap;\n    margin: 12px auto;\n  }\n  .payment-icons .footer__payment-icon {\n    width: 36px;\n    height: auto;\n    display: inline-block;\n    transition: opacity 0.2s ease-in-out, transform 0.2s;\n  }\n  .payment-icons .footer__payment-icon:hover {\n    opacity: 0.85;\n    transform: translateY(-1px);\n  }\n</style>\n\n<div class=\"payment-icons\">\n  {% assign methods = \"visa,master,american_express,ideal,bancontact,klarna,belfius,kbc_cbc\" | split: \",\" %}\n  {% for type in methods %}\n    {{ type | strip | payment_type_svg_tag: class: 'footer__payment-icon' }}\n  {% endfor %}\n</div>",
        "color_scheme": "",
        "padding_top": 0,
        "padding_bottom": 0
