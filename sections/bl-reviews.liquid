{%- style -%}
  .bl-reviews-sp {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    padding: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px 0 {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .bl-reviews-sp {
      padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
    }
  }
  .bl-reviews-sp__inner {
    max-width: {{ settings.page_width | default: 1200 }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .bl-reviews-sp__header {
    text-align: center;
    margin-bottom: 28px;
  }
  .bl-reviews-sp__heading {
    margin: 0 0 6px;
    font-size: 24px;
  }
  @media screen and (min-width: 750px) {
    .bl-reviews-sp__heading { font-size: 28px; }
  }
  .bl-reviews-sp__overall {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    margin-top: 10px;
  }
  .bl-reviews-sp__stars-row { display: flex; gap: 3px; }
  .bl-reviews-sp__stars-row svg { width: 20px; height: 20px; fill: #facc15; }
  .bl-reviews-sp__score-text {
    font-size: 15px;
    font-weight: 700;
  }
  .bl-reviews-sp__count-text {
    font-size: 14px;
    opacity: 0.6;
  }

  /* Review cards grid */
  .bl-reviews-sp__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media screen and (min-width: 750px) {
    .bl-reviews-sp__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media screen and (min-width: 990px) {
    .bl-reviews-sp__grid { grid-template-columns: repeat({{ section.settings.columns }}, 1fr); }
  }

  .bl-reviews-sp__card {
    background: {{ section.settings.card_bg }};
    border-radius: 10px;
    padding: 22px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .bl-reviews-sp__card-stars { display: flex; gap: 2px; }
  .bl-reviews-sp__card-stars svg { width: 15px; height: 15px; fill: #facc15; }
  .bl-reviews-sp__card-text {
    font-size: 14px;
    line-height: 1.55;
    font-style: italic;
    opacity: 0.85;
    margin: 0;
    flex-grow: 1;
  }
  .bl-reviews-sp__card-author {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-top: 4px;
  }
  .bl-reviews-sp__card-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: {{ section.settings.avatar_bg }};
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
    color: {{ section.settings.avatar_text }};
    flex-shrink: 0;
  }
  .bl-reviews-sp__card-name {
    font-size: 13px;
    font-weight: 600;
  }
  .bl-reviews-sp__card-product {
    font-size: 12px;
    opacity: 0.5;
  }
  .bl-reviews-sp__card-verified {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    color: #22c55e;
    font-weight: 600;
    margin-top: 2px;
  }
  .bl-reviews-sp__card-verified svg { width: 13px; height: 13px; }
{%- endstyle -%}

<div class="bl-reviews-sp">
  <div class="bl-reviews-sp__inner">

    {%- if section.settings.heading != blank -%}
      <div class="bl-reviews-sp__header">
        <h2 class="bl-reviews-sp__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.show_overall -%}
          <div class="bl-reviews-sp__overall">
            <div class="bl-reviews-sp__stars-row">
              {%- assign sc = section.settings.overall_score | times: 1.0 -%}
              {%- assign fl = sc | floor -%}
              {%- for i in (1..5) -%}
                {%- if i <= fl -%}
                  <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="#d1d5db"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <span class="bl-reviews-sp__score-text">{{ section.settings.overall_score }}/5</span>
            <span class="bl-reviews-sp__count-text">op basis van {{ section.settings.overall_count }} reviews</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign review_blocks = section.blocks | where: "type", "review" -%}
    {%- if review_blocks.size > 0 -%}
      <div class="bl-reviews-sp__grid">
        {%- for block in review_blocks -%}
          <div class="bl-reviews-sp__card" {{ block.shopify_attributes }}>
            <div class="bl-reviews-sp__card-stars">
              {%- assign rs = block.settings.stars | times: 1 -%}
              {%- for i in (1..5) -%}
                {%- if i <= rs -%}
                  <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- else -%}
                  <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="#d1d5db"/></svg>
                {%- endif -%}
              {%- endfor -%}
            </div>
            <p class="bl-reviews-sp__card-text">"{{ block.settings.text }}"</p>
            <div class="bl-reviews-sp__card-author">
              <div class="bl-reviews-sp__card-avatar">{{ block.settings.name | slice: 0 }}</div>
              <div>
                <div class="bl-reviews-sp__card-name">{{ block.settings.name }}</div>
                {%- if block.settings.product != blank -%}
                  <div class="bl-reviews-sp__card-product">{{ block.settings.product }}</div>
                {%- endif -%}
              </div>
            </div>
            {%- if block.settings.verified -%}
              <div class="bl-reviews-sp__card-verified">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                Geverifieerde aankoop
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "BL Reviews",
  "tag": "section",
  "class": "bl-reviews-section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Koptekst",
      "default": "Wat onze klanten zeggen"
    },
    {
      "type": "checkbox",
      "id": "show_overall",
      "label": "Totaalscore tonen",
      "default": true
    },
    {
      "type": "text",
      "id": "overall_score",
      "label": "Totaalscore",
      "default": "4.8"
    },
    {
      "type": "text",
      "id": "overall_count",
      "label": "Aantal reviews",
      "default": "120+"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Kolommen (desktop)",
      "default": 3
    },
    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Achtergrond",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekst",
      "default": "#121212"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Kaart achtergrond",
      "default": "#f7f7f7"
    },
    {
      "type": "color",
      "id": "avatar_bg",
      "label": "Avatar achtergrond",
      "default": "#FF7A15"
    },
    {
      "type": "color",
      "id": "avatar_text",
      "label": "Avatar tekst",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Ruimte"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding boven",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding onder",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "stars",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Sterren",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review tekst",
          "default": "Super leuk cadeau, echt een aanrader!"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Naam",
          "default": "Lisa M."
        },
        {
          "type": "text",
          "id": "product",
          "label": "Product (optioneel)",
          "default": "100 Date Activiteiten"
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Geverifieerde aankoop",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BL Reviews",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "text": "Super leuk cadeau voor mijn vriend, we hebben er al zoveel samen afgekrast!",
            "name": "Lisa M.",
            "product": "100 Date Activiteiten",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "text": "Mooie kwaliteit poster en snel geleverd. Heel leuk om samen in te vullen.",
            "name": "Jasper K.",
            "product": "100 Films",
            "verified": true
          }
        },
        {
          "type": "review",
          "settings": {
            "stars": 5,
            "text": "Perfect cadeau voor bierliefhebbers! Kraslaag werkt heel goed.",
            "name": "Sanne V.",
            "product": "100 Biertjes",
            "verified": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
