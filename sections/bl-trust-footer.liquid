{%- style -%}
  .bl-trust-footer {
    background: {{ section.settings.bg_color }};
    color: {{ section.settings.text_color }};
    border-top: 1px solid {{ section.settings.border_color }};
  }
  .bl-trust-footer__inner {
    max-width: {{ settings.page_width | default: 1200 }}px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ===== USP BAR ===== */
  .bl-trust-footer__usps {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 10px 28px;
    padding: 18px 0;
    border-bottom: 1px solid {{ section.settings.border_color }};
  }
  .bl-trust-footer__usp {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
  }
  .bl-trust-footer__usp svg {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  /* ===== MAIN GRID ===== */
  .bl-trust-footer__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
    padding: 36px 0 28px;
  }
  @media screen and (min-width: 750px) {
    .bl-trust-footer__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 40px;
    }
  }
  @media screen and (min-width: 990px) {
    .bl-trust-footer__grid {
      grid-template-columns: 1.3fr 1fr 1fr 1fr;
      gap: 20px 40px;
    }
  }

  /* ===== COLUMN STYLES ===== */
  .bl-trust-footer__col-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    margin: 0 0 14px;
    color: {{ section.settings.heading_color }};
  }

  /* Brand col */
  .bl-trust-footer__brand-logo {
    max-width: 160px;
    height: auto;
    margin-bottom: 12px;
  }
  .bl-trust-footer__brand-text {
    font-size: 13px;
    line-height: 1.55;
    opacity: 0.75;
    margin: 0 0 16px;
    max-width: 300px;
  }

  /* Review badge */
  .bl-trust-footer__review {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 14px;
    background: {{ section.settings.border_color }};
    border-radius: 8px;
    font-size: 13px;
  }
  .bl-trust-footer__stars {
    display: flex;
    gap: 2px;
  }
  .bl-trust-footer__stars svg {
    width: 14px;
    height: 14px;
    fill: #facc15;
  }
  .bl-trust-footer__review-score { font-weight: 700; }
  .bl-trust-footer__review-count { opacity: 0.55; font-size: 12px; }

  /* Link lists */
  .bl-trust-footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .bl-trust-footer__links a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
    font-size: 13px;
    opacity: 0.75;
    transition: opacity 0.2s;
  }
  .bl-trust-footer__links a:hover { opacity: 1; }

  /* Contact */
  .bl-trust-footer__contact-row {
    display: flex;
    align-items: flex-start;
    gap: 9px;
    margin-bottom: 9px;
    font-size: 13px;
    opacity: 0.8;
  }
  .bl-trust-footer__contact-row a {
    color: {{ section.settings.text_color }};
    text-decoration: none;
  }
  .bl-trust-footer__contact-row a:hover { opacity: 0.7; }
  .bl-trust-footer__contact-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    margin-top: 1px;
  }
  .bl-trust-footer__contact-icon svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ section.settings.accent_color }};
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Social icons */
  .bl-trust-footer__social {
    display: flex;
    gap: 10px;
    margin-top: 14px;
  }
  .bl-trust-footer__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: {{ section.settings.border_color }};
    transition: background 0.2s;
    text-decoration: none;
  }
  .bl-trust-footer__social a:hover { background: {{ section.settings.accent_color }}; }
  .bl-trust-footer__social svg {
    width: 15px;
    height: 15px;
    fill: none;
    stroke: {{ section.settings.text_color }};
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ===== BOTTOM BAR ===== */
  .bl-trust-footer__bottom {
    border-top: 1px solid {{ section.settings.border_color }};
    padding: 18px 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  @media screen and (min-width: 750px) {
    .bl-trust-footer__bottom {
      flex-direction: row;
      justify-content: space-between;
    }
  }
  .bl-trust-footer__copyright {
    font-size: 12px;
    opacity: 0.45;
  }
  .bl-trust-footer__payments {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .bl-trust-footer__payments svg,
  .bl-trust-footer__payments .footer__payment-icon {
    width: 34px;
    height: auto;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .bl-trust-footer__payments svg:hover,
  .bl-trust-footer__payments .footer__payment-icon:hover { opacity: 1; }
  .bl-trust-footer__policies {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .bl-trust-footer__policies a {
    font-size: 12px;
    opacity: 0.45;
    color: {{ section.settings.text_color }};
    text-decoration: none;
  }
  .bl-trust-footer__policies a:hover { opacity: 0.8; }
  .bl-trust-footer__kvk {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 11px;
    opacity: 0.4;
    margin-top: 4px;
  }
  @media screen and (min-width: 750px) {
    .bl-trust-footer__kvk { margin-top: 0; }
  }
{%- endstyle -%}

<div class="bl-trust-footer">
  <div class="bl-trust-footer__inner">

    {%- comment -%} ===== USP BAR ===== {%- endcomment -%}
    {%- assign usp_blocks = section.blocks | where: "type", "usp" -%}
    {%- if usp_blocks.size > 0 -%}
      <div class="bl-trust-footer__usps">
        {%- for block in usp_blocks -%}
          <div class="bl-trust-footer__usp" {{ block.shopify_attributes }}>
            {%- case block.settings.icon -%}
              {%- when 'truck' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
              {%- when 'shield' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              {%- when 'star' -%}
                <svg viewBox="0 0 24 24" fill="{{ section.settings.accent_color }}" stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              {%- when 'gift' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
              {%- when 'heart' -%}
                <svg viewBox="0 0 24 24" fill="{{ section.settings.accent_color }}" stroke="none"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
              {%- when 'clock' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {%- when 'return' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
              {%- when 'check' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="{{ section.settings.accent_color }}" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            {%- endcase -%}
            <span>{{ block.settings.text }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} ===== MAIN GRID ===== {%- endcomment -%}
    <div class="bl-trust-footer__grid">

      {%- for block in section.blocks -%}
        {%- case block.type -%}

          {%- when 'brand' -%}
            <div {{ block.shopify_attributes }}>
              {%- if block.settings.logo != blank -%}
                <img src="{{ block.settings.logo | image_url: width: 320 }}" alt="{{ shop.name }}" class="bl-trust-footer__brand-logo" loading="lazy" width="{{ block.settings.logo.width }}" height="{{ block.settings.logo.height }}">
              {%- else -%}
                <h3 class="bl-trust-footer__col-title">{{ shop.name }}</h3>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="bl-trust-footer__brand-text">{{ block.settings.description }}</p>
              {%- endif -%}
              {%- if block.settings.show_reviews -%}
                <div class="bl-trust-footer__review">
                  <div class="bl-trust-footer__stars">
                    {%- assign score_float = block.settings.review_score | times: 1.0 -%}
                    {%- assign full = score_float | floor -%}
                    {%- assign rest = score_float | minus: full -%}
                    {%- for i in (1..5) -%}
                      {%- if i <= full -%}
                        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- elsif i == full | plus: 1 and rest >= 0.3 and rest <= 0.7 -%}
                        <svg viewBox="0 0 24 24"><defs><linearGradient id="hf-{{ block.id }}"><stop offset="50%" stop-color="#facc15"/><stop offset="50%" stop-color="#d1d5db"/></linearGradient></defs><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="url(#hf-{{ block.id }})"/></svg>
                      {%- elsif i == full | plus: 1 and rest > 0.7 -%}
                        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" fill="#d1d5db"/></svg>
                      {%- endif -%}
                    {%- endfor -%}
                  </div>
                  <span class="bl-trust-footer__review-score">{{ block.settings.review_score }}/5</span>
                  <span class="bl-trust-footer__review-count">({{ block.settings.review_count }})</span>
                </div>
              {%- endif -%}
              {%- if block.settings.kvk != blank or block.settings.btw != blank -%}
                <div class="bl-trust-footer__kvk" style="margin-top:12px;">
                  {%- if block.settings.kvk != blank -%}<span>KVK: {{ block.settings.kvk }}</span>{%- endif -%}
                  {%- if block.settings.btw != blank -%}<span>BTW: {{ block.settings.btw }}</span>{%- endif -%}
                </div>
              {%- endif -%}
            </div>

          {%- when 'menu' -%}
            <div {{ block.shopify_attributes }}>
              <h3 class="bl-trust-footer__col-title">{{ block.settings.heading }}</h3>
              {%- if block.settings.menu != blank -%}
                <ul class="bl-trust-footer__links">
                  {%- for link in block.settings.menu.links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>

          {%- when 'contact' -%}
            <div {{ block.shopify_attributes }}>
              <h3 class="bl-trust-footer__col-title">{{ block.settings.heading | default: "Contact" }}</h3>
              {%- if block.settings.email != blank -%}
                <div class="bl-trust-footer__contact-row">
                  <span class="bl-trust-footer__contact-icon"><svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></span>
                  <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
                </div>
              {%- endif -%}
              {%- if block.settings.phone != blank -%}
                <div class="bl-trust-footer__contact-row">
                  <span class="bl-trust-footer__contact-icon"><svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.81.36 1.6.7 2.35a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.75.34 1.54.57 2.35.7A2 2 0 0 1 22 16.92z"/></svg></span>
                  <a href="tel:{{ block.settings.phone | remove: ' ' }}">{{ block.settings.phone }}</a>
                </div>
              {%- endif -%}
              {%- if block.settings.whatsapp != blank -%}
                <div class="bl-trust-footer__contact-row">
                  <span class="bl-trust-footer__contact-icon"><svg viewBox="0 0 24 24" fill="{{ section.settings.accent_color }}" stroke="none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.555 4.126 1.528 5.86L.06 23.49a.5.5 0 00.611.611l5.63-1.468A11.94 11.94 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.94 9.94 0 01-5.38-1.572l-.386-.232-3.336.87.87-3.336-.232-.386A9.94 9.94 0 012 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg></span>
                  <a href="https://wa.me/{{ block.settings.whatsapp | remove: '+' | remove: ' ' | remove: '-' }}" target="_blank" rel="noopener">WhatsApp</a>
                </div>
              {%- endif -%}
              {%- if block.settings.address != blank -%}
                <div class="bl-trust-footer__contact-row">
                  <span class="bl-trust-footer__contact-icon"><svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg></span>
                  <span>{{ block.settings.address }}</span>
                </div>
              {%- endif -%}
              {%- if block.settings.show_social -%}
                <div class="bl-trust-footer__social">
                  {%- if settings.social_instagram_link != blank -%}
                    <a href="{{ settings.social_instagram_link }}" target="_blank" rel="noopener" aria-label="Instagram"><svg viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1.2" fill="{{ section.settings.text_color }}" stroke="none"/></svg></a>
                  {%- endif -%}
                  {%- if settings.social_facebook_link != blank -%}
                    <a href="{{ settings.social_facebook_link }}" target="_blank" rel="noopener" aria-label="Facebook"><svg viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></a>
                  {%- endif -%}
                  {%- if settings.social_tiktok_link != blank -%}
                    <a href="{{ settings.social_tiktok_link }}" target="_blank" rel="noopener" aria-label="TikTok"><svg viewBox="0 0 24 24"><path d="M9 12a4 4 0 104 4V4a5 5 0 005 5"/></svg></a>
                  {%- endif -%}
                  {%- if settings.social_youtube_link != blank -%}
                    <a href="{{ settings.social_youtube_link }}" target="_blank" rel="noopener" aria-label="YouTube"><svg viewBox="0 0 24 24"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.33 29 29 0 00-.46-5.33z"/><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="{{ section.settings.border_color }}"/></svg></a>
                  {%- endif -%}
                  {%- if settings.social_pinterest_link != blank -%}
                    <a href="{{ settings.social_pinterest_link }}" target="_blank" rel="noopener" aria-label="Pinterest"><svg viewBox="0 0 24 24" fill="{{ section.settings.text_color }}" stroke="none"><path d="M12 2C6.5 2 2 6.5 2 12c0 4.1 2.5 7.6 6 9.2 0-.7 0-1.6.2-2.4l1.4-5.8s-.3-.7-.3-1.8c0-1.7 1-2.9 2.2-2.9 1 0 1.5.8 1.5 1.7 0 1-.7 2.6-1 4-.3 1.2.6 2.2 1.8 2.2 2.1 0 3.5-2.7 3.5-5.9 0-2.4-1.6-4.2-4.5-4.2-3.3 0-5.3 2.4-5.3 5.2 0 .9.3 1.6.7 2.1.1.1.1.2.1.3l-.3 1c0 .2-.2.3-.4.2-1.4-.6-2.1-2.2-2.1-4 0-3.2 2.7-7.1 8-7.1 4.3 0 7.1 3.1 7.1 6.4 0 4.4-2.4 7.7-6 7.7-1.2 0-2.3-.6-2.7-1.4l-.7 2.8c-.3 1-.8 2-1.3 2.8 1 .3 2 .5 3.1.5 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg></a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>

        {%- endcase -%}
      {%- endfor -%}

    </div>

    {%- comment -%} ===== BOTTOM BAR ===== {%- endcomment -%}
    <div class="bl-trust-footer__bottom">
      <div>
        <div class="bl-trust-footer__copyright">&copy; {{ 'now' | date: "%Y" }} {{ shop.name }}. Alle rechten voorbehouden.</div>
      </div>

      {%- if section.settings.show_payments -%}
        <div class="bl-trust-footer__payments">
          {%- assign methods = section.settings.payment_methods | split: "," -%}
          {%- for type in methods -%}
            {{ type | strip | payment_type_svg_tag: class: 'footer__payment-icon' }}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_policies -%}
        <div class="bl-trust-footer__policies">
          {%- if shop.privacy_policy -%}<a href="{{ shop.privacy_policy.url }}">{{ shop.privacy_policy.title }}</a>{%- endif -%}
          {%- if shop.terms_of_service -%}<a href="{{ shop.terms_of_service.url }}">{{ shop.terms_of_service.title }}</a>{%- endif -%}
          {%- if shop.refund_policy -%}<a href="{{ shop.refund_policy.url }}">{{ shop.refund_policy.title }}</a>{%- endif -%}
          {%- if shop.shipping_policy -%}<a href="{{ shop.shipping_policy.url }}">{{ shop.shipping_policy.title }}</a>{%- endif -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</div>

{% schema %}
{
  "name": "BL Trust Footer",
  "tag": "section",
  "class": "bl-trust-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Kleuren"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Achtergrondkleur",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Tekstkleur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Koptekst kleur",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent kleur (iconen)",
      "default": "#FF7A15"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Scheidingslijnen",
      "default": "#2a2a2a"
    },
    {
      "type": "header",
      "content": "Betaalmethoden"
    },
    {
      "type": "checkbox",
      "id": "show_payments",
      "label": "Betaaliconen tonen",
      "default": true
    },
    {
      "type": "text",
      "id": "payment_methods",
      "label": "Methoden (komma-gescheiden)",
      "default": "visa,master,ideal,bancontact,klarna,american_express",
