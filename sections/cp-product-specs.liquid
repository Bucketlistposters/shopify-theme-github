{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ps-{{ section.id }} .ps-heading {
    margin: 0 0 32px;
    text-align: {{ section.settings.heading_alignment }};
  }

  .ps-{{ section.id }} .ps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }
  @media screen and (min-width: 750px) {
    .ps-{{ section.id }} .ps-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .ps-{{ section.id }} .ps-group {
    border-top: 1px solid rgba(0,0,0,0.1);
    padding: 20px 0;
  }
  @media screen and (min-width: 750px) {
    .ps-{{ section.id }} .ps-group {
      padding: 24px 20px;
    }
    .ps-{{ section.id }} .ps-group:nth-child(odd) { padding-left: 0; }
    .ps-{{ section.id }} .ps-group:nth-child(even) { border-left: 1px solid rgba(0,0,0,0.1); }
  }

  .ps-{{ section.id }} .ps-group-title {
    margin: 0 0 12px;
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.5;
    font-weight: 600;
  }

  .ps-{{ section.id }} .ps-specs-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ps-{{ section.id }} .ps-spec {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 14px;
    line-height: 1.5;
  }

  .ps-{{ section.id }} .ps-spec-label {
    opacity: 0.65;
  }

  .ps-{{ section.id }} .ps-spec-value {
    font-weight: 600;
    text-align: right;
  }

  /* Dimension visual */
  .ps-{{ section.id }} .ps-dimensions {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 4px;
  }

  .ps-{{ section.id }} .ps-dim {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: 12px 16px;
    border-radius: 10px;
    background: {{ section.settings.dim_bg }};
    min-width: 70px;
  }

  .ps-{{ section.id }} .ps-dim-value {
    font-size: 18px;
    font-weight: 700;
    line-height: 1;
  }

  .ps-{{ section.id }} .ps-dim-label {
    font-size: 11px;
    opacity: 0.5;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Richtext content for free-form specs */
  .ps-{{ section.id }} .ps-richtext {
    font-size: 14px;
    line-height: 1.6;
    opacity: 0.8;
  }
  .ps-{{ section.id }} .ps-richtext p { margin: 0 0 6px; }
  .ps-{{ section.id }} .ps-richtext ul { padding-left: 18px; margin: 0; }
  .ps-{{ section.id }} .ps-richtext li { margin-bottom: 4px; }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding ps-{{ section.id }}">
    {%- if section.settings.heading != blank -%}
      <h2 class="ps-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- comment -%} Dimensions row {%- endcomment -%}
    {%- if section.settings.show_dimensions -%}
      <div style="margin-bottom: 24px;">
        <p class="ps-group-title">Formaat en gewicht</p>
        <div class="ps-dimensions">
          {%- if section.settings.dim_length != blank -%}
            <div class="ps-dim">
              <span class="ps-dim-value">{{ section.settings.dim_length }}</span>
              <span class="ps-dim-label">Lengte</span>
            </div>
          {%- endif -%}
          {%- if section.settings.dim_width != blank -%}
            <div class="ps-dim">
              <span class="ps-dim-value">{{ section.settings.dim_width }}</span>
              <span class="ps-dim-label">Breedte</span>
            </div>
          {%- endif -%}
          {%- if section.settings.dim_height != blank -%}
            <div class="ps-dim">
              <span class="ps-dim-value">{{ section.settings.dim_height }}</span>
              <span class="ps-dim-label">Hoogte</span>
            </div>
          {%- endif -%}
          {%- if section.settings.dim_weight != blank -%}
            <div class="ps-dim">
              <span class="ps-dim-value">{{ section.settings.dim_weight }}</span>
              <span class="ps-dim-label">Gewicht</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="ps-grid">
      {%- for block in section.blocks -%}
        <div class="ps-group" {{ block.shopify_attributes }}>
          {%- if block.settings.group_title != blank -%}
            <p class="ps-group-title">{{ block.settings.group_title | escape }}</p>
          {%- endif -%}

          {%- if block.type == 'spec_list' -%}
            <ul class="ps-specs-list">
              {%- if block.settings.spec_1_label != blank -%}
                <li class="ps-spec"><span class="ps-spec-label">{{ block.settings.spec_1_label | escape }}</span><span class="ps-spec-value">{{ block.settings.spec_1_value | escape }}</span></li>
              {%- endif -%}
              {%- if block.settings.spec_2_label != blank -%}
                <li class="ps-spec"><span class="ps-spec-label">{{ block.settings.spec_2_label | escape }}</span><span class="ps-spec-value">{{ block.settings.spec_2_value | escape }}</span></li>
              {%- endif -%}
              {%- if block.settings.spec_3_label != blank -%}
                <li class="ps-spec"><span class="ps-spec-label">{{ block.settings.spec_3_label | escape }}</span><span class="ps-spec-value">{{ block.settings.spec_3_value | escape }}</span></li>
              {%- endif -%}
              {%- if block.settings.spec_4_label != blank -%}
                <li class="ps-spec"><span class="ps-spec-label">{{ block.settings.spec_4_label | escape }}</span><span class="ps-spec-value">{{ block.settings.spec_4_value | escape }}</span></li>
              {%- endif -%}
              {%- if block.settings.spec_5_label != blank -%}
                <li class="ps-spec"><span class="ps-spec-label">{{ block.settings.spec_5_label | escape }}</span><span class="ps-spec-value">{{ block.settings.spec_5_value | escape }}</span></li>
              {%- endif -%}
              {%- if block.settings.spec_6_label != blank -%}
                <li class="ps-spec"><span class="ps-spec-label">{{ block.settings.spec_6_label | escape }}</span><span class="ps-spec-value">{{ block.settings.spec_6_value | escape }}</span></li>
              {%- endif -%}
            </ul>
          {%- elsif block.type == 'richtext' -%}
            <div class="ps-richtext rte">{{ block.settings.content }}</div>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CP - Product Specificaties",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Productspecificaties" },
    { "type": "select", "id": "heading_size", "options": [
      { "value": "h2", "label": "Small" },
      { "value": "h1", "label": "Medium" },
      { "value": "h0", "label": "Large" }
    ], "default": "h1", "label": "Heading grootte" },
    { "type": "select", "id": "heading_alignment", "options": [
      { "value": "left", "label": "Links" },
      { "value": "center", "label": "Midden" }
    ], "default": "left", "label": "Heading uitlijning" },
    { "type": "header", "content": "Afmetingen" },
    { "type": "checkbox", "id": "show_dimensions", "label": "Toon afmetingen", "default": true },
    { "type": "text", "id": "dim_length", "label": "Lengte", "default": "70 cm" },
    { "type": "text", "id": "dim_width", "label": "Breedte", "default": "50 cm" },
    { "type": "text", "id": "dim_height", "label": "Hoogte", "default": "20 cm" },
    { "type": "text", "id": "dim_weight", "label": "Gewicht", "default": "1350 g" },
    { "type": "color", "id": "dim_bg", "label": "Afmeting kaart achtergrond", "default": "#f5f5f5" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurenschema", "default": "scheme-1" },
    { "type": "header", "content": "Sectie padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding boven" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding onder" }
  ],
  "blocks": [
    {
      "type": "spec_list",
      "name": "Specificatie lijst",
      "settings": [
        { "type": "text", "id": "group_title", "label": "Groepstitel", "default": "Technische specificaties" },
        { "type": "text", "id": "spec_1_label", "label": "Spec 1 label", "default": "Materiaal buitenhoes" },
        { "type": "text", "id": "spec_1_value", "label": "Spec 1 waarde", "default": "Polyester blend" },
        { "type": "text", "id": "spec_2_label", "label": "Spec 2 label" },
        { "type": "text", "id": "spec_2_value", "label": "Spec 2 waarde" },
        { "type": "text", "id": "spec_3_label", "label": "Spec 3 label" },
        { "type": "text", "id": "spec_3_value", "label": "Spec 3 waarde" },
        { "type": "text", "id": "spec_4_label", "label": "Spec 4 label" },
        { "type": "text", "id": "spec_4_value", "label": "Spec 4 waarde" },
        { "type": "text", "id": "spec_5_label", "label": "Spec 5 label" },
        { "type": "text", "id": "spec_5_value", "label": "Spec 5 waarde" },
        { "type": "text", "id": "spec_6_label", "label": "Spec 6 label" },
        { "type": "text", "id": "spec_6_value", "label": "Spec 6 waarde" }
      ]
    },
    {
      "type": "richtext",
      "name": "Vrije tekst",
      "settings": [
        { "type": "text", "id": "group_title", "label": "Groepstitel", "default": "Wasvoorschriften" },
        { "type": "richtext", "id": "content", "label": "Inhoud", "default": "<p>Buitenhoes wasbaar op 40 graden.</p>" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CP - Product Specificaties",
      "blocks": [
        { "type": "spec_list", "settings": { "group_title": "Technische specificaties", "spec_1_label": "Materiaal", "spec_1_value": "Memory foam", "spec_2_label": "Keurmerk", "spec_2_value": "OEKO-TEX Standard 100", "spec_3_label": "Garantie", "spec_3_value": "2 jaar" } },
        { "type": "richtext", "settings": { "group_title": "Wasvoorschriften", "content": "<p>Buitenhoes wasbaar op 40 graden. Niet in de droger.</p>" } }
      ]
    }
  ]
}
{% endschema %}
