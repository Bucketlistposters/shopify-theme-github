{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .gb-{{ section.id }} .gb-wrapper {
    display: flex;
    flex-direction: column-reverse;
    gap: 32px;
    align-items: center;
  }
  @media screen and (min-width: 750px) {
    .gb-{{ section.id }} .gb-wrapper {
      flex-direction: row;
      gap: 48px;
    }
    .gb-{{ section.id }} .gb-wrapper--reversed { flex-direction: row-reverse; }
  }

  .gb-{{ section.id }} .gb-content {
    flex: 1;
  }

  .gb-{{ section.id }} .gb-heading {
    margin: 0 0 16px;
    line-height: 1.2;
  }
  .gb-{{ section.id }} .gb-heading em,
  .gb-{{ section.id }} .gb-heading i {
    font-style: italic;
    opacity: 0.7;
  }

  .gb-{{ section.id }} .gb-text {
    font-size: 15px;
    line-height: 1.7;
    opacity: 0.8;
    margin: 0 0 24px;
  }

  .gb-{{ section.id }} .gb-btn {
    display: inline-flex;
  }

  .gb-{{ section.id }} .gb-image-wrap {
    flex: 0 0 100%;
    width: 100%;
    max-width: 400px;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
  }
  @media screen and (min-width: 750px) {
    .gb-{{ section.id }} .gb-image-wrap {
      flex: 0 0 40%;
      max-width: none;
    }
  }

  .gb-{{ section.id }} .gb-image-wrap img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .gb-{{ section.id }} .gb-checks {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .gb-{{ section.id }} .gb-check {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    font-weight: 500;
  }

  .gb-{{ section.id }} .gb-check-icon {
    flex-shrink: 0;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: {{ section.settings.check_color }};
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gb-{{ section.id }} .gb-check-icon svg {
    width: 12px;
    height: 12px;
    stroke: #fff;
    fill: none;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding gb-{{ section.id }}">
    <div class="gb-wrapper{% if section.settings.image_position == 'right' %} gb-wrapper--reversed{% endif %}">
      {%- if section.settings.image != blank -%}
        <div class="gb-image-wrap">
          <img
            src="{{ section.settings.image | image_url: width: 800 }}"
            alt="{{ section.settings.heading | strip_html | escape }}"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        </div>
      {%- endif -%}

      <div class="gb-content">
        {%- if section.settings.heading != blank -%}
          <h2 class="gb-heading {{ section.settings.heading_size }}">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.text != blank -%}
          <div class="gb-text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="gb-checks">
            {%- for block in section.blocks -%}
              <li class="gb-check" {{ block.shopify_attributes }}>
                <span class="gb-check-icon">
                  <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {{ block.settings.text | escape }}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <a href="{{ section.settings.button_link | default: '#' }}" class="button button--primary gb-btn">
            {{ section.settings.button_label | escape }}
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "CP - Garantie Banner",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Bevalt het toch niet? <em>Geen probleem!</em>" },
    { "type": "select", "id": "heading_size", "options": [
      { "value": "h2", "label": "Small" },
      { "value": "h1", "label": "Medium" },
      { "value": "h0", "label": "Large" }
    ], "default": "h1", "label": "Heading grootte" },
    { "type": "richtext", "id": "text", "label": "Tekst", "default": "<p>We weten zeker dat je tevreden zult zijn. Mocht dat toch niet zo zijn, dan kun je het product eenvoudig gratis retourneren.</p>" },
    { "type": "text", "id": "button_label", "label": "Knoptekst", "default": "Bestel nu" },
    { "type": "url", "id": "button_link", "label": "Knoplink" },
    { "type": "header", "content": "Afbeelding" },
    { "type": "image_picker", "id": "image", "label": "Afbeelding" },
    { "type": "select", "id": "image_position", "options": [
      { "value": "left", "label": "Links" },
      { "value": "right", "label": "Rechts" }
    ], "default": "left", "label": "Afbeelding positie" },
    { "type": "range", "id": "image_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 16, "label": "Afbeelding border radius" },
    { "type": "header", "content": "Stijl" },
    { "type": "color", "id": "check_color", "label": "Vinkje kleur", "default": "#2EAE4E" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurenschema", "default": "scheme-1" },
    { "type": "header", "content": "Sectie padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding boven" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding onder" }
  ],
  "blocks": [
    {
      "type": "check_item",
      "name": "Checklijst item",
      "settings": [
        { "type": "text", "id": "text", "label": "Tekst", "default": "100 nachten proefslapen" }
      ]
    }
  ],
  "presets": [
    {
      "name": "CP - Garantie Banner",
      "blocks": [
        { "type": "check_item", "settings": { "text": "100 nachten proefslapen" } },
        { "type": "check_item", "settings": { "text": "Gratis thuisbezorgd" } },
        { "type": "check_item", "settings": { "text": "2 jaar garantie" } }
      ]
    }
  ]
}
{% endschema %}
