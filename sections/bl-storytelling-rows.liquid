{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .str-{{ section.id }} .str-block {
    display: flex;
    flex-direction: column;
    gap: 24px;
    align-items: center;
    padding: 0 0 48px;
  }
  .str-{{ section.id }} .str-block:last-child { padding-bottom: 0; }

  @media screen and (min-width: 750px) {
    .str-{{ section.id }} .str-block {
      flex-direction: row;
      gap: 48px;
      padding: 0 0 64px;
    }
    .str-{{ section.id }} .str-block--reversed { flex-direction: row-reverse; }
  }

  .str-{{ section.id }} .str-media {
    flex: 0 0 100%;
    width: 100%;
    position: relative;
    border-radius: {{ section.settings.media_radius }}px;
    overflow: hidden;
    aspect-ratio: {{ section.settings.media_aspect_ratio }};
    background: #f3f3f3;
  }
  @media screen and (min-width: 750px) {
    .str-{{ section.id }} .str-media {
      flex: 0 0 calc(50% - 24px);
      width: calc(50% - 24px);
    }
  }

  .str-{{ section.id }} .str-media video,
  .str-{{ section.id }} .str-media img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  .str-{{ section.id }} .str-media .str-poster {
    z-index: 2;
    transition: opacity 0.4s ease;
    cursor: pointer;
  }
  .str-{{ section.id }} .str-media .str-poster.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .str-{{ section.id }} .str-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    z-index: 3;
    width: 52px; height: 52px;
    border-radius: 50%;
    border: none;
    background: rgba(18,18,18,0.75);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s, opacity 0.3s;
    padding: 0;
  }
  .str-{{ section.id }} .str-play svg { width: 18px; height: 18px; fill: #fff; margin-left: 2px; }
  .str-{{ section.id }} .str-play:hover { transform: translate(-50%, -50%) scale(1.08); }
  .str-{{ section.id }} .str-play.is-hidden { opacity: 0; pointer-events: none; }

  .str-{{ section.id }} .str-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .str-{{ section.id }} .str-label {
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.45;
    margin: 0 0 10px;
    font-weight: 600;
  }

  .str-{{ section.id }} .str-heading {
    margin: 0 0 16px;
    line-height: 1.2;
  }

  .str-{{ section.id }} .str-text {
    margin: 0;
    line-height: 1.7;
    opacity: 0.75;
    font-size: 15px;
  }

  .str-{{ section.id }} .str-btn {
    margin-top: 24px;
    display: inline-flex;
    align-self: flex-start;
  }

  .str-{{ section.id }} .str-media--image-only img {
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    object-fit: cover;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding str-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="str-block{% if section.settings.alternate_layout %}{% cycle '', ' str-block--reversed' %}{% elsif block.settings.reversed %} str-block--reversed{% endif %}" {{ block.shopify_attributes }}>
        <div class="str-media{% unless block.settings.video != blank %} str-media--image-only{% endunless %}">
          {%- if block.settings.video != blank -%}
            <video
              src="{{ block.settings.video.sources[1].url | default: block.settings.video.sources[0].url }}"
              playsinline muted loop
              preload="metadata"
              data-str-video
            ></video>
            {%- assign poster_img = block.settings.image | default: block.settings.video.preview_image -%}
            {%- if poster_img -%}
              <img class="str-poster" src="{{ poster_img | image_url: width: 900 }}" alt="{{ block.settings.heading | strip_html | escape }}" loading="lazy" data-str-poster>
            {%- endif -%}
            <button class="str-play" aria-label="Video afspelen" data-str-play>
              <svg viewBox="0 0 20 20"><path d="M6 4l12 6-12 6V4z"/></svg>
            </button>
          {%- elsif block.settings.image != blank -%}
            <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.heading | strip_html | escape }}" loading="lazy">
          {%- else -%}
            <div style="position:absolute;inset:0;background:#f3f3f3;display:flex;align-items:center;justify-content:center;color:#999;">Afbeelding of video</div>
          {%- endif -%}
        </div>
        <div class="str-content">
          {%- if block.settings.label != blank -%}
            <p class="str-label">{{ block.settings.label | escape }}</p>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}
            <h2 class="str-heading {{ section.settings.heading_size }}">{{ block.settings.heading }}</h2>
          {%- endif -%}
          {%- if block.settings.text != blank -%}
            <div class="str-text rte">{{ block.settings.text }}</div>
          {%- endif -%}
          {%- if block.settings.button_label != blank -%}
            <a href="{{ block.settings.button_link | default: '#' }}" class="button button--primary str-btn">{{ block.settings.button_label | escape }}</a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

<script>
  (function() {
    var section = document.querySelector('.str-{{ section.id }}');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var video = entry.target.querySelector('[data-str-video]');
        if (!video) return;
        var poster = entry.target.querySelector('[data-str-poster]');
        var playBtn = entry.target.querySelector('[data-str-play]');
        if (entry.isIntersecting) {
          video.play().then(function() {
            if (poster) poster.classList.add('is-hidden');
            if (playBtn) playBtn.classList.add('is-hidden');
          }).catch(function() {});
        } else { video.pause(); }
      });
    }, { threshold: 0.4 });
    section.querySelectorAll('.str-media').forEach(function(m) { observer.observe(m); });
    section.querySelectorAll('[data-str-play]').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var media = btn.closest('.str-media');
        var video = media.querySelector('[data-str-video]');
        if (video) { video.play(); btn.classList.add('is-hidden'); var p=media.querySelector('[data-str-poster]'); if(p) p.classList.add('is-hidden'); }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "BL - Storytelling Rijen",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "select", "id": "heading_size", "options": [
      { "value": "h2", "label": "Small" },{ "value": "h1", "label": "Medium" },{ "value": "h0", "label": "Large" }
    ], "default": "h1", "label": "Heading grootte" },
    { "type": "checkbox", "id": "alternate_layout", "label": "Automatisch afwisselen links/rechts", "default": true },
    { "type": "range", "id": "media_radius", "min": 0, "max": 30, "step": 2, "unit": "px", "default": 12, "label": "Media border radius" },
    { "type": "text", "id": "media_aspect_ratio", "label": "Media aspect ratio", "default": "4/3", "info": "Bijv. 4/3, 16/9, 1/1" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurenschema", "default": "scheme-1" },
    { "type": "header", "content": "Sectie padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding boven" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36, "label": "Padding onder" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Media + Tekst Rij",
      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Afbeelding (of video cover)" },
        { "type": "text", "id": "label", "label": "Label (optioneel)" },
        { "type": "inline_richtext", "id": "heading", "label": "Heading", "default": "Waarom dit product?" },
        { "type": "richtext", "id": "text", "label": "Tekst", "default": "<p>Beschrijf hier een uniek voordeel van je product.</p>" },
        { "type": "text", "id": "button_label", "label": "Knoptekst" },
        { "type": "url", "id": "button_link", "label": "Knoplink" },
        { "type": "checkbox", "id": "reversed", "label": "Media rechts", "default": false, "info": "Alleen als afwisselen uit staat" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BL - Storytelling Rijen",
      "blocks": [
        { "type": "row", "settings": { "heading": "Ontdek wat het bijzonder maakt" } },
        { "type": "row", "settings": { "heading": "Gemaakt met zorg voor detail" } },
        { "type": "row", "settings": { "heading": "Perfect als cadeau" } }
      ]
    }
  ]
}
{% endschema %}
