{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .usp-{{ section.id }} .usp-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
    text-align: center;
  }
  @media screen and (min-width: 750px) {
    .usp-{{ section.id }} .usp-grid {
      grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
      gap: 24px;
    }
  }

  .usp-{{ section.id }} .usp-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 24px 16px;
    border-radius: {{ section.settings.card_radius }}px;
    background: {{ section.settings.card_bg }};
    border: 1px solid rgba(18,18,18,0.06);
  }

  .usp-{{ section.id }} .usp-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ section.settings.icon_color }};
  }
  .usp-{{ section.id }} .usp-icon img,
  .usp-{{ section.id }} .usp-icon svg {
    width: 100%; height: 100%; object-fit: contain;
  }

  .usp-{{ section.id }} .usp-title {
    margin: 0;
    font-size: 14px;
    font-weight: 700;
    line-height: 1.3;
  }

  .usp-{{ section.id }} .usp-desc {
    margin: 0;
    font-size: 13px;
    line-height: 1.5;
    opacity: 0.6;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding usp-{{ section.id }}">
    <div class="usp-grid">
      {%- for block in section.blocks -%}
        <div class="usp-item" {{ block.shopify_attributes }}>
          <div class="usp-icon">
            {%- if block.settings.icon_image != blank -%}
              <img src="{{ block.settings.icon_image | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}" loading="lazy">
            {%- else -%}
              {%- case block.settings.icon -%}
                {%- when 'shield' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
                {%- when 'truck' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                {%- when 'return' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 2.13-9.36L1 10"/></svg>
                {%- when 'star' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                {%- when 'heart' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                {%- when 'gift' -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
                {%- else -%}
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="m9 12 2 2 4-4"/></svg>
              {%- endcase -%}
            {%- endif -%}
          </div>
          {%- if block.settings.title != blank -%}
            <h3 class="usp-title">{{ block.settings.title | escape }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="usp-desc">{{ block.settings.description | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "BL - USP Balk",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    { "type": "range", "id": "icon_size", "min": 24, "max": 80, "step": 4, "unit": "px", "default": 36, "label": "Icoon grootte" },
    { "type": "color", "id": "icon_color", "label": "Icoon kleur", "default": "#121212" },
    { "type": "range", "id": "card_radius", "min": 0, "max": 24, "step": 2, "unit": "px", "default": 10, "label": "Kaart border radius" },
    { "type": "color", "id": "card_bg", "label": "Kaart achtergrond", "default": "#f3f3f3" },
    { "type": "color_scheme", "id": "color_scheme", "label": "Kleurenschema", "default": "scheme-1" },
    { "type": "header", "content": "Sectie padding" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 24, "label": "Padding boven" },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 24, "label": "Padding onder" }
  ],
  "blocks": [
    {
      "type": "usp_item",
      "name": "USP Item",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icoon", "options": [
          { "value": "shield", "label": "Schild (garantie)" },
          { "value": "truck", "label": "Vrachtwagen (verzending)" },
          { "value": "return", "label": "Retour" },
          { "value": "star", "label": "Ster" },
          { "value": "heart", "label": "Hart" },
          { "value": "gift", "label": "Cadeau" },
          { "value": "check", "label": "Vinkje" }
        ], "default": "truck" },
        { "type": "image_picker", "id": "icon_image", "label": "Eigen icoon (optioneel)" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Snelle levering" },
        { "type": "text", "id": "description", "label": "Beschrijving", "default": "Volgende werkdag in huis" }
      ]
    }
  ],
  "presets": [
    {
      "name": "BL - USP Balk",
      "blocks": [
        { "type": "usp_item", "settings": { "icon": "truck", "title": "Snelle levering", "description": "Volgende werkdag in huis" } },
        { "type": "usp_item", "settings": { "icon": "star", "title": "Hoge kwaliteit", "description": "Premium materialen" } },
        { "type": "usp_item", "settings": { "icon": "gift", "title": "Perfect cadeau", "description": "Leuk om te geven en te krijgen" } }
      ]
    }
  ]
}
{% endschema %}
